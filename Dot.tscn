[sub_resource type="GDScript" id="GDScript_g4v7s"]
resource_name = "Dot"
script/source = "extends Area2D

const FREQ : float = 1.0
const POWR : float = 1.0

var Wave : float = 0.0

func _ready() -> void:
	Wave = position.x * 0.1

func _process(delta: float) -> void:
	Wave = fmod(Wave + delta * FREQ, 1.0)
	$Sprite.position.y = sin(Wave * TAU) * POWR

func collected() -> void:
	queue_free()
"

